{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignore": ["workflows/**"],
  "ignoreBinaries": ["python3"],
  "ignoreExportsUsedInFile": true,
  "workspaces": {
    "mcp-server": {
      "entry": ["src/cli.ts", "scripts/*.mjs"],
      "project": ["src/**/*.ts"]
    },
    "mcp-proxy": {
      "entry": ["src/index.ts", "scripts/*.mjs"],
      "project": ["src/**/*.ts"]
    }
  }
}
