node_modules/
coverage/
*.log
.DS_Store
.sprint-orchestrator/
.crew/
__pycache__/
*.pyc

# BMad tooling — installed/generated, not source
_bmad/
_bmad-output/
# Exception: the BMad adapter's test fixtures contain a fake `_bmad-output/`
# tree (committed test data, not local planning artefacts).
!plugins/crew/mcp-server/src/adapters/bmad/fixtures/**/_bmad-output/
!plugins/crew/mcp-server/src/adapters/bmad/fixtures/**/_bmad-output/**
.claude/skills/bmad-*/

# ...but track the active planning artifacts (PRD, epics, architecture, etc.)
# so remote agents and future readers can ground in them. Everything else
# under _bmad-output/ — including the internal archive/ subfolder — stays
# ignored.
!_bmad-output/
_bmad-output/*
!_bmad-output/planning-artifacts/
!_bmad-output/planning-artifacts/**
_bmad-output/planning-artifacts/archive/
!_bmad-output/implementation-artifacts/
!_bmad-output/implementation-artifacts/**

# Claude Code runtime — generated per-session/per-machine, not source
.claude/scheduled_tasks.lock
.claude/*.lock
.claude/settings.local.json
.claude/*.local.json
.claude/skills/ship-story/.runs/
.worktrees/
.claude/worktrees/
.claude/workflows/
